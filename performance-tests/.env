# ============================================
# Performance Tests — Variáveis de Ambiente
# ============================================

# URL alvo da API
BASE_URL=https://dummyjson.com

# ─── Perfil de carga ──────────────────────────────────────────────────────────
#
#  Define qual perfil o k6 executa ao rodar: yarn test:gate
#
#  load  → 500 VUs por 5 min sustentados (padrão — critério da tarefa)
#  spike → pico repentino de 1000 VUs, detecta burst e rate limiting
#  soak  → 200 VUs por 30 min, detecta degradação temporal e memory leak
#
STAGES_PROFILE=load

# ─── Configuração do perfil LOAD ──────────────────────────────────────────────
#
#  500 VUs simultâneos por 5 minutos sustentados.
#  Estágios:
#    ramp-up   → sobe gradualmente (evita thundering herd)
#    sustain   → carga plena — janela de coleta das métricas reais
#    ramp-down → descida controlada para observar recuperação
#
LOAD_MAX_VUS=500
LOAD_RAMPUP_DURATION=1m
LOAD_SUSTAIN_DURATION=5m
LOAD_RAMPDOWN_DURATION=30s

# ─── Configuração do perfil SPIKE ─────────────────────────────────────────────
#
#  Pico repentino de 1000 VUs (2x o load) seguido de queda abrupta.
#  Detecta: pool de conexões esgotado, rate limiting, GC pressure.
#  Estágios:
#    baseline   → tráfego estável antes do pico
#    peak       → pico abrupto
#    recovery   → queda + observação da recuperação
#
SPIKE_BASELINE_VUS=50
SPIKE_PEAK_VUS=1000
SPIKE_BASELINE_DURATION=30s
SPIKE_PEAK_DURATION=30s
SPIKE_RECOVERY_DURATION=30s

# ─── Configuração do perfil SOAK (Endurance) ──────────────────────────────────
#
#  200 VUs por 30 minutos.
#  Detecta: vazamentos de memória, crescimento de latência ao longo do tempo,
#  esgotamento de connection pool.
#  Estágios:
#    ramp-up   → aquecimento lento
#    sustain   → carga sustentada — janela de observação
#    ramp-down → resfriamento
#
SOAK_MAX_VUS=200
SOAK_RAMPUP_DURATION=2m
SOAK_SUSTAIN_DURATION=28m
SOAK_RAMPDOWN_DURATION=2m
