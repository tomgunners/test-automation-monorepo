# ============================================
# Performance Tests — Variáveis de Ambiente
# ============================================

# URL alvo da API
BASE_URL=https://dummyjson.com

# ─── Perfil de carga ──────────────────────────────────────────────────────────
#
#  smoke → 2 VUs / 30s   — sanity check (padrão no CI — rápido e leve)
#  load  → 500 VUs / ~6m — baseline de performance
#  spike → 1000 VUs / ~2m — teste de burst
#  soak  → 200 VUs / 30m — endurance / memory leak
#
STAGES_PROFILE=load

# ─── Configuração do perfil SMOKE ─────────────────────────────────────────────
#
#  Sanity check rápido — verifica que todos os endpoints respondem
#  com status 200 e body não vazio. Não simula carga real.
#  Thresholds relaxados: p(95)<5000ms, error rate<5%.
#
SMOKE_VUS=2
SMOKE_DURATION=30s

# ─── Configuração do perfil LOAD ──────────────────────────────────────────────
LOAD_MAX_VUS=500
LOAD_RAMPUP_DURATION=1m
LOAD_SUSTAIN_DURATION=5m
LOAD_RAMPDOWN_DURATION=30s

# ─── Configuração do perfil SPIKE ─────────────────────────────────────────────
SPIKE_BASELINE_VUS=50
SPIKE_PEAK_VUS=1000
SPIKE_BASELINE_DURATION=30s
SPIKE_PEAK_DURATION=30s
SPIKE_RECOVERY_DURATION=30s

# ─── Configuração do perfil SOAK (Endurance) ──────────────────────────────────
SOAK_MAX_VUS=200
SOAK_RAMPUP_DURATION=2m
SOAK_SUSTAIN_DURATION=28m
SOAK_RAMPDOWN_DURATION=2m
