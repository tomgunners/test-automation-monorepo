{
  "name": "performance-tests",
  "version": "1.0.0",
  "description": "Testes de Performance com k6",
  "private": true,
  "scripts": {
    "test:smoke": "cross-env STAGES_PROFILE=smoke node scripts/k6-runner.js src/scenarios/products.test.js",
    "test:gate": "node scripts/k6-runner.js src/scenarios/products.test.js",
    "test:informative": "node scripts/k6-runner.js --no-thresholds src/scenarios/products.test.js",
    "test:load": "cross-env STAGES_PROFILE=load node scripts/k6-runner.js src/scenarios/products.test.js",
    "test:spike": "cross-env STAGES_PROFILE=spike node scripts/k6-runner.js src/scenarios/products.test.js",
    "test:soak": "cross-env STAGES_PROFILE=soak node scripts/k6-runner.js src/scenarios/products.test.js",
    "test:report": "node src/utils/generate-report.js && open-cli results/report.html",
    "clean": "rimraf results"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "open-cli": "^8.0.0",
    "rimraf": "^5.0.5"
  }
}
