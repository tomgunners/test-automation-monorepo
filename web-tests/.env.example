# ============================================
# Web Tests — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO deve ser commitado no repositório.
# ============================================

# URL base da aplicação
BASE_URL=https://www.saucedemo.com

# Configurações do browser
# HEADLESS=true  → sem janela (recomendado para CI)
# HEADLESS=false → janela visível (debug local)
HEADLESS=true
BROWSER=chromium
SLOW_MO=0

# Timeouts (ms)
DEFAULT_TIMEOUT=10000
NAVIGATION_TIMEOUT=60000

# ─── Credenciais dos usuários de teste ────────────────────────────────────────
# Nunca inclua credenciais reais neste arquivo.
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
LOCKED_USER=locked_out_user
INVALID_USER=invalid_user
INVALID_PASSWORD=wrong_password
