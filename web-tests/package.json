{
  "name": "web-tests",
  "version": "1.0.0",
  "description": "Testes E2E com Playwright + Cucumber + TypeScript",
  "private": true,
  "scripts": {
    "test": "cucumber-js --profile default",
    "test:smoke": "cucumber-js --profile smoke",
    "test:regression": "cucumber-js --profile regression",
    "report:cucumber": "open-cli test-results/cucumber-report.html",
    "report:allure": "allure generate allure-results -o allure-report --clean && allure open allure-report",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "playwright:install": "playwright install --with-deps chromium",
    "clean": "rimraf test-results allure-results allure-report dist && mkdir -p test-results allure-results",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@automation/shared": "*",
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.42.1",
    "allure-cucumberjs": "^3.0.0",
    "allure-js-commons": "^3.0.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "open-cli": "^8.0.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
