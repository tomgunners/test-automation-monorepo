{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@client/*":  ["src/client/*"],
      "@schemas/*": ["src/schemas/*"],
      "@utils/*":   ["src/utils/*"],
      "@config/*":  ["src/config/*"],
      "@automation/shared": ["../shared/src/index"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports",
    "allure-results",
    "allure-report"
  ]
}