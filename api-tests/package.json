{
  "name": "api-tests",
  "version": "1.0.0",
  "description": "Testes de API com Supertest + Mocha + Chai + TypeScript",
  "private": true,
  "scripts": {
    "test": "mocha --require ts-node/register --require tsconfig-paths/register --require src/config/setup.ts 'src/tests/**/*.test.ts' --reporter mocha-multi-reporters --reporter-options configFile=reporter-config.json",
    "test:watch": "mocha --require ts-node/register --require tsconfig-paths/register --require src/config/setup.ts 'src/tests/**/*.test.ts' --watch",
    "test:report": "open-cli reports/api-report.html",
    "report:allure": "allure generate allure-results -o allure-report --clean && allure open allure-report",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "clean": "rimraf reports allure-results allure-report dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@automation/shared": "*",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "mocha": "^10.3.0",
    "mocha-multi-reporters": "^1.5.1",
    "mochawesome": "^7.1.3",
    "allure-mocha": "^3.0.0",
    "allure-js-commons": "^3.0.0",
    "supertest": "^6.3.4"
  },
  "devDependencies": {
    "@types/chai": "^4.3.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "open-cli": "^8.0.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
