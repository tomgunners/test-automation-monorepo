# ============================================================
# Mobile Tests — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO deve ser commitado no repositório.
# ============================================================

APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

ANDROID_PLATFORM_VERSION=15
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_APP_NAME=wdio-native-demo-app.apk

ELEMENT_TIMEOUT=15000
TEST_TIMEOUT=120000
APPIUM_COMMAND_TIMEOUT=300

# Credenciais do app — substitua pelos valores reais do seu ambiente
STANDARD_USER=bob@example.com
STANDARD_PASSWORD=10203040
INVALID_USER=nao-e-um-email
INVALID_PASSWORD=curta
