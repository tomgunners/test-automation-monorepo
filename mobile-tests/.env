# ============================================================
# Mobile Tests — Variáveis de Ambiente
# ============================================================

# ── Appium Server ────────────────────────────────────────────
# Appium deve estar rodando antes de executar os testes.
# Inicie com: appium
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Android ─────────────────────────────────────────────────
# Versão do Android no emulador/dispositivo.
# Verificar com: adb shell getprop ro.build.version.release
ANDROID_PLATFORM_VERSION=14
# Serial do emulador ou dispositivo físico.
# Verificar com: adb devices
ANDROID_DEVICE_NAME=emulator-5554
# Caminho absoluto para o APK (relativo à pasta apps/).
ANDROID_APP_NAME=wdio-native-demo-app.apk

# ── iOS ──────────────────────────────────────────────────────
# Verificar simuladores disponíveis: xcrun simctl list devices available
IOS_PLATFORM_VERSION=17.0
IOS_DEVICE_NAME=iPhone 15
IOS_APP_NAME=wdio-native-demo-app.app

# ── Timeouts ─────────────────────────────────────────────────
WDIO_WAIT_TIMEOUT=15000
APPIUM_IMPLICIT_WAIT=10000
APPIUM_COMMAND_TIMEOUT=300
ELEMENT_TIMEOUT=15000
TEST_TIMEOUT=120000

# ── Credenciais do app ───────────────────────────────────────
STANDARD_USER=bob@example.com
STANDARD_PASSWORD=10203040
INVALID_USER=aaaaaaaaaaaaaaa
INVALID_PASSWORD=senhaerrada

# ── Ambiente ─────────────────────────────────────────────────
TEST_ENV=QA
