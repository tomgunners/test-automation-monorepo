# ============================================================
# Mobile Tests — Variáveis de Ambiente
# ============================================================

# Appium Server (iniciado manualmente antes dos testes)
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Android ─────────────────────────────────────────────────
ANDROID_PLATFORM_VERSION=15
# Obter com: adb devices
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_APP_NAME=wdio-native-demo-app.apk

# ── Timeouts (ms) ───────────────────────────────────────────
# Tempo máximo aguardando elemento aparecer
ELEMENT_TIMEOUT=15000
# Timeout global de cada teste (mocha)
TEST_TIMEOUT=120000
# Tempo máximo sem comandos antes do Appium encerrar sessão
APPIUM_COMMAND_TIMEOUT=300

# Credenciais do app
STANDARD_USER=aaaaaaaa
STANDARD_PASSWORD=10203040
INVALID_USER=aaaaaaaaaaaaaaa
INVALID_PASSWORD=senhaerrada